{
  "mcpServers": {
    "luxgen": {
      "command": "node",
      "args": ["apps/mcp-server/dist/index.js"],
      "env": {
        "LUXGEN_GRAPHQL_URL": "http://localhost:4000/graphql",
        "LUXGEN_TENANT": "demo",
        "LUXGEN_JWT": "paste-your-jwt-without-Bearer-prefix"
      }
    },
    "luxgen-api-key": {
      "command": "node",
      "args": ["apps/mcp-server/dist/index.js"],
      "env": {
        "LUXGEN_GRAPHQL_URL": "http://localhost:4000/graphql",
        "LUXGEN_TENANT": "demo",
        "LUXGEN_MCP_API_KEY": "luxgen_mcp_your-secret-key"
      }
    }
  }
}
