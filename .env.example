# ─────────────────────────────────────────────────────────────────────────────
# LuxGen Monorepo — Root Environment Variables
# Copy to .env.local at repo root (or per-app .env files — see apps/*/ .env.example).
# All URL defaults are defined in packages/config/src/url-defaults.ts
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Application URLs (single source of truth) ─────────────────────────────────
# Web app origin (server + links in emails/notifications)
WEB_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API base URL
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# GraphQL endpoint (defaults to ${API_URL}/graphql if unset)
GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# Local LLM (Agent Studio / automations)
OLLAMA_HOST=http://localhost:11434

# ── Multi-tenant routing ──────────────────────────────────────────────────────
# Base domain for tenant subdomains (demo.localhost in dev, yourdomain.com in prod)
APP_DOMAIN=localhost
NEXT_PUBLIC_APP_DOMAIN=localhost

# Comma-separated tenant subdomains for dev CORS + tenant-not-found links
TENANT_SUBDOMAINS=demo,idea-vibes

# ── CORS (API) ────────────────────────────────────────────────────────────────
# Single origin or comma-separated list (CORS_ORIGINS takes precedence)
CORS_ORIGIN=http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,http://demo.localhost:3000

# ── Data stores ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/luxgen_dev
REDIS_URL=redis://localhost:6379

# ── Ports (optional — used when URLs are derived from APP_DOMAIN=localhost) ─
WEB_PORT=3000
API_PORT=4000
