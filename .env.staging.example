# ─────────────────────────────────────────────────────────────────────────────
# LuxGen Staging Environment Variables
# Copy to .env.staging and fill in real values.
# Run: docker compose -f docker-compose.staging.yml --env-file .env.staging up -d
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=staging

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-me-staging-strong-password
MONGO_DATABASE=luxgen_staging

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-staging-jwt-secret-min-32-chars-long

# ── URLs ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Agent Studio ──────────────────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:7b
