# ─────────────────────────────────────────────────────────────────────────────
# LuxGen API — Environment Variables
# Copy to apps/api/.env for local development.
# In Docker/CI, pass these as environment variables directly.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Local (no auth): mongodb://localhost:27017/luxgen_dev
# Docker:          mongodb://admin:password123@mongodb:27017/luxgen_dev?authSource=admin
# Staging/Prod:    mongodb+srv://user:pass@cluster.mongodb.net/luxgen_prod
MONGODB_URI=mongodb://localhost:27017/luxgen_dev

# ── Cache ─────────────────────────────────────────────────────────────────────
# Local Docker: redis://localhost:6379
# Staging/Prod: redis://user:pass@redis-host:6379
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED: Change this in all non-dev environments. Min 32 chars.
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ── Tenants ───────────────────────────────────────────────────────────────────
# Per-tenant signing keys — add one per tenant
TENANT_DEMO_KEY=demo-tenant-signing-key-dev-32chars-min
TENANT_IDEA-VIBES_KEY=idea-vibes-signing-key-dev-32chars-min

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowlist; if unset, derived from WEB_APP_URL + TENANT_SUBDOMAINS
CORS_ORIGIN=http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,http://demo.localhost:3000

# Multi-tenant routing
APP_DOMAIN=localhost
TENANT_SUBDOMAINS=demo,idea-vibes

# ── GraphQL ───────────────────────────────────────────────────────────────────
# Set to false in production
APOLLO_INTROSPECTION=true

# ── Billing (Stripe) — Phase 9 ───────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
# Simulate upgrades without Stripe in local dev
BILLING_DEV_MODE=true
# Optional: Stripe metered item for automation run overages
# STRIPE_METER_AUTOMATION_RUNS_ITEM=si_...

# Business listing subscriptions (directory listings)
STRIPE_PRICE_LISTING=price_...
WEB_APP_URL=http://localhost:3000
EMAIL_PROVIDER=log
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=
# EMAIL_FROM=noreply@yourdomain.com

# Listing reminder intervals (days)
LISTING_REMINDER_DRAFT_DAYS=3
LISTING_REMINDER_NEED_INFO_DAYS=2
LISTING_REMINDER_PAYMENT_DAYS=1
LISTING_REMINDER_EXPIRED_DAYS=7

# Cron job auth for POST /api/jobs/listing-reminders
# JOBS_API_KEY=your-secret-key

# ── Internal URLs ─────────────────────────────────────────────────────────────
WEB_APP_URL=http://localhost:3000
API_URL=http://localhost:4000
GRAPHQL_URL=http://localhost:4000/graphql
OLLAMA_HOST=http://localhost:11434
