# LuxGen MCP server — copy to repo root .env or set in Cursor mcp.json
LUXGEN_GRAPHQL_URL=http://localhost:4000/graphql
LUXGEN_TENANT=demo

# Auth — use ONE of (stdio mode only; HTTP uses request headers):
LUXGEN_JWT=
LUXGEN_MCP_API_KEY=

# Optional override when using API key (default: fetched from mcpKeyContext)
# LUXGEN_MCP_SCOPES=read,write

# Transport: stdio (Cursor) or http (production / remote clients)
MCP_TRANSPORT=stdio

# HTTP transport (MCP_TRANSPORT=http)
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=3100
# MCP_HTTP_PATH=/mcp
# MCP_RATE_LIMIT_MAX=120
# MCP_RATE_LIMIT_WINDOW_MS=60000
# MCP_ALLOWED_HOSTS=localhost:3100
