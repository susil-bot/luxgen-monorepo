# LuxGen MCP server — copy to repo root .env or set in Cursor mcp.json
LUXGEN_GRAPHQL_URL=http://localhost:4000/graphql
LUXGEN_TENANT=demo

# Auth — use ONE of:
LUXGEN_JWT=
LUXGEN_MCP_API_KEY=

# Optional override when using API key (default: fetched from mcpKeyContext)
# LUXGEN_MCP_SCOPES=read,write

MCP_TRANSPORT=stdio
