# Copy to apps/mobile/.env.local for local development
# iOS Simulator: localhost works. Android emulator: use 10.0.2.2 instead of localhost.

EXPO_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
# Android emulator: replace localhost with 10.0.2.2
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_DEFAULT_TENANT=demo

# White-label / per-tenant builds — leave blank for the default LuxGen app
EXPO_PUBLIC_TENANT_SLUG=
EXPO_PUBLIC_APP_NAME=LuxGen
