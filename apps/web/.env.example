# ─────────────────────────────────────────────────────────────────────────────
# LuxGen Web App — Environment Variables
# Copy to apps/web/.env.local for local development.
# In Docker/CI, pass these as environment variables directly.
# ─────────────────────────────────────────────────────────────────────────────

# ── App Environment ───────────────────────────────────────────────────────────
NODE_ENV=development

# ── API URLs ──────────────────────────────────────────────────────────────────
# Resolved via @luxgen/config — see packages/config/src/urls.ts
# Local dev: http://localhost:4000 | Production: https://api.yourdomain.com
WEB_APP_URL=http://localhost:3000
API_URL=http://localhost:4000
GRAPHQL_URL=http://localhost:4000/graphql

# Public vars — exposed to the browser. NEVER put secrets here.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_APP_ENV=development

# Multi-tenant subdomain base (demo.localhost in dev)
APP_DOMAIN=localhost
NEXT_PUBLIC_APP_DOMAIN=localhost
TENANT_SUBDOMAINS=demo,idea-vibes

# Stripe publishable key (browser-safe) — optional until Stripe Checkout is live
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Must match apps/api JWT_SECRET — required for pages/api/users/me token verify
JWT_SECRET=dev-jwt-secret-change-in-production

# ── Agent Studio — Local LLM (Ollama) ────────────────────────────────────────
# Ollama must be running. Install from https://ollama.ai or use Docker.
#
# Available models (pull with: ollama pull <model>):
#   mistral:latest        — 4.1 GB  — good general model, fast
#   qwen2.5-coder:7b      — 4.7 GB  — best for code generation (RECOMMENDED)
#   qwen2.5-coder:1.5b   — 1.0 GB  — fastest, limited quality
#   qwen2.5-coder:14b    — 9.0 GB  — best quality, needs 16 GB RAM
#   deepseek-coder-v2:lite — 9.1 GB — alternative top performer
#
# In Docker (compose): change OLLAMA_HOST to http://ollama:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:latest

# ── Agent Studio — Git worktree pipeline (Phase 5) ─────────────────────────
# local  = filesystem apply only (default)
# dev    = git worktree + branch per session (requires git repo)
AGENT_DEPLOYMENT_MODE=local
AGENT_GIT_ENABLED=false
AGENT_GIT_BASE_BRANCH=main
AGENT_AUTO_MERGE=false

# Phase 6 — persistence & headless queue (enable for dev/staging)
# AGENT_MONGODB_URI=mongodb://admin:password123@localhost:27017/luxgen_dev?authSource=admin
# AGENT_REDIS_URL=redis://localhost:6379
# AGENT_QUEUE_ENABLED=true
# AGENT_MONGODB_FORCE=true
