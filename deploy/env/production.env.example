# LuxGen — Production environment template
# Copy sections to your platform's secret store (Vercel, Render, Fly).
# Full reference: docs/deployment/ENV_PRODUCTION.md

# ── Web (Vercel) ──────────────────────────────────────────────────────────────
# NODE_ENV=production
# WEB_APP_URL=https://your-app.vercel.app
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# API_URL=https://luxgen-api.onrender.com
# NEXT_PUBLIC_API_URL=https://luxgen-api.onrender.com
# NEXT_PUBLIC_GRAPHQL_URL=https://luxgen-api.onrender.com/graphql
# APP_DOMAIN=yourdomain.com
# NEXT_PUBLIC_APP_DOMAIN=yourdomain.com

# ── API (Render / Fly) ────────────────────────────────────────────────────────
# NODE_ENV=production
# PORT=4000
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/luxgen_prod
# REDIS_URL=rediss://default:pass@host.upstash.io:6379
# JWT_SECRET=CHANGE_ME_min_32_characters_random
# WEB_APP_URL=https://your-app.vercel.app
# API_URL=https://luxgen-api.onrender.com
# GRAPHQL_URL=https://luxgen-api.onrender.com/graphql
# CORS_ORIGIN=https://your-app.vercel.app
# CORS_ORIGINS=https://your-app.vercel.app,https://demo.yourdomain.com
# APP_DOMAIN=yourdomain.com
# TENANT_SUBDOMAINS=demo,idea-vibes
# APOLLO_INTROSPECTION=false
# BILLING_DEV_MODE=false
# WEB_APP_URL=https://your-app.vercel.app
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_BUSINESS=price_...
# STRIPE_PRICE_LISTING=price_...
# EMAIL_PROVIDER=log
# JOBS_API_KEY=random-cron-secret
