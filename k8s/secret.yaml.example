# k8s/secret.yaml.example
#
# DO NOT commit k8s/secret.yaml to source control.
# k8s/secret.yaml is in .gitignore.
#
# HOW TO CREATE THE SECRET:
#
#   Option A (recommended) — from env file:
#     cp deploy/env/production.env.example .env.production
#     # fill in real values in .env.production
#     kubectl create secret generic luxgen-secrets \
#       --namespace=luxgen \
#       --from-env-file=.env.production \
#       --dry-run=client -o yaml | kubectl apply -f -
#
#   Option B — from literals:
#     kubectl create secret generic luxgen-secrets \
#       --namespace=luxgen \
#       --from-literal=MONGODB_URI='...' \
#       --from-literal=JWT_SECRET='...' \
#       ... (see keys below)
#
#   Option C (production-grade) — Sealed Secrets or External Secrets Operator:
#     https://sealed-secrets.netlify.app/
#     https://external-secrets.io/
#
# REQUIRED SECRET KEYS:
#
#   MONGODB_URI                    Full MongoDB connection string (include ?replicaSet=rs0 for in-cluster mongo)
#   JWT_SECRET                     Min 32 chars, cryptographically random
#   JWT_EXPIRES_IN                 e.g. 7d
#   SEED_IF_EMPTY                  true | false
#   TENANT_DEMO_KEY                Min 32 chars — per-tenant JWT signing key
#   TENANT_IDEA-VIBES_KEY          Min 32 chars — per-tenant JWT signing key
#   MONGO_INITDB_ROOT_USERNAME     MongoDB root username (for in-cluster mongo)
#   MONGO_INITDB_ROOT_PASSWORD     MongoDB root password (for in-cluster mongo)
#   MONGO_INITDB_DATABASE          Database name (for in-cluster mongo)
#
# OPTIONAL SECRET KEYS:
#
#   STRIPE_SECRET_KEY              sk_live_... or sk_test_...
#   STRIPE_WEBHOOK_SECRET          whsec_...
#   STRIPE_PRICE_STARTER           price_...
#   STRIPE_PRICE_PRO               price_...
#   STRIPE_PRICE_BUSINESS          price_...
#   STRIPE_PRICE_LISTING           price_...
#   JOBS_API_KEY                   Random string for internal job auth
#   SMTP_HOST                      SMTP server hostname
#   SMTP_PORT                      e.g. 587
#   SMTP_USER                      SMTP username
#   SMTP_PASS                      SMTP password
#
# Generate a secure random JWT_SECRET:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
