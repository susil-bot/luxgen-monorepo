{
  "name": "luxgen-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/select-tenant.js && turbo run build",
    "build:web": "turbo run build --filter=@luxgen/web",
    "build:api": "turbo run build --filter=@luxgen/api",
    "build:api:deps": "turbo run build --filter=@luxgen/api^...",
    "build:demo": "node scripts/select-tenant.js demo && turbo run build",
    "build:idea-vibes": "node scripts/select-tenant.js idea-vibes && turbo run build",
    "build:acme-corp": "node scripts/select-tenant.js acme-corp && turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@luxgen/api",
    "dev:web": "turbo run dev --filter=@luxgen/web",
    "dev:mobile": "turbo run dev --filter=@luxgen/mobile",
    "dev:stack:web": "bash scripts/dev-stack.sh web",
    "dev:stack:admin": "bash scripts/dev-stack.sh admin",
    "dev:stack:mobile": "bash scripts/dev-stack.sh mobile",
    "dev:stack:api": "bash scripts/dev-stack.sh api",
    "dev:agent-worker": "turbo run dev --filter=@luxgen/agent-worker",
    "dev:mcp": "npm run build:mcp && node apps/mcp-server/dist/index.js",
    "build:mcp": "turbo run build --filter=@luxgen/mcp-server^... --filter=@luxgen/mcp-server",
    "dev:docker": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dev:docker:detach": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build -d",
    "dev:docker:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:clean": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down -v && docker system prune -f",
    "lint": "oxlint --ignore-path .oxlintignore --quiet apps packages",
    "lint:all": "oxlint --ignore-path .oxlintignore apps packages",
    "lint:fix": "oxlint --fix --fix-suggestions --ignore-path .oxlintignore apps packages",
    "format": "oxfmt --check apps packages",
    "format:fix": "oxfmt --write apps packages",
    "quality": "npm run lint && npm run format",
    "quality:fix": "npm run lint:fix && npm run format:fix",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "prepare": "husky",
    "validate": "sh scripts/validate.sh",
    "validate:build": "sh scripts/validate-build.sh",
    "init:tenant-workflow": "node scripts/init-tenant-workflow.js",
    "init:tenants": "node scripts/init-tenants.js",
    "select-tenant": "node scripts/select-tenant.js"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.0.0",
    "husky": "^9.1.7",
    "is-potential-custom-element-name": "^1.0.1",
    "lint-staged": "^15.5.2",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "turbo": "^1.10.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
